		$idUser = $this->global['idUser'];
		//$pending = $this->db->get_where("ap_cart_temp_no",array("status" => 0,"tanggal like '".date('Y-m-d')."%'"));
		$this->db->select("setoran_kasir.*,users.first_name");
		$this->db->from("setoran_kasir");
