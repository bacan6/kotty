		//UPDATE POIN CUSTOMER 

		//dapatkan poin lama
		$poin_lama = $this->model1->poin_lama($id_customer);
		$ulang_tahun = $this->model1->ulang_tahun($id_customer);

		//update poin customer setelah transaksi 
