							if(strtotime(date('H:i:s')) >= strtotime($row->JamMulai) && strtotime(date('H:i:s')) <= strtotime($row->JamSelesai)){
								$diskon = ($cekQty > $maksimum)? $maksimum*$row->discount:$cekQty*$row->discount;
